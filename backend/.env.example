# ========== APPLICATION SETTINGS ==========
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# ========== SUPABASE DATABASE ==========
# Get from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========== GEMINI API (Content Generation) ==========
# Get from Google AI Studio: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBWdnIg...

# ========== JWT & ENCRYPTION SECURITY ==========
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
ENCRYPTION_KEY=your-super-secret-encryption-key-min-32-characters

# ========== CORS & FRONTEND URL ==========
# For local development
FRONTEND_URL=http://localhost:3000

# For production, set to your actual domain
# FRONTEND_URL=https://yourdomain.com

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ========== CRON JOBS ==========
# Internal token for protecting cron endpoints
INTERNAL_CRON_TOKEN=your-internal-cron-token

# ========== OPTIONAL: ERROR TRACKING ==========
# SENTRY_DSN=https://xxxxx@sentry.io/123456

# ========== OPTIONAL: REDIS CACHE ==========
# REDIS_URL=redis://localhost:6379

